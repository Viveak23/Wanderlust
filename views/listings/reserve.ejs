<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <div class="row">

        <!-- LEFT SIDE - BOOKING FORM -->
        <div class="col-md-7">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <h3 class="fw-bold mb-4">Confirm & Pay</h3>

                <form action="/listings/<%= listing._id %>/book" method="POST"class = "needs-validation" novalidate>

                    <!-- Dates -->
                    <div class="row mb-3">
                        <div class="col">
                            <label class="form-label">Check-in</label>
                            <input type="date" name="checkin" id="checkin"
                                class="form-control rounded-3" required>
                                <div class = "invalid-feedback">please enter checkin date</div>
                        </div>
                        <div class="col">
                            <label class="form-label">Check-out</label>
                            <input type="date" name="checkout" id="checkout"
                                class="form-control rounded-3" required>
                                <div class = "invalid-feedback">please enter checkout date</div>
                        </div>
                    </div>

                    <!-- Guests -->
                    <div class="mb-3">
                        <label class="form-label">Guests</label>
                        <input type="number" min="1" value="1"
                            class="form-control rounded-3">
                    </div>

                    <hr>

                    <!-- Payment Section -->
                    <h5 class="fw-bold mt-3">Payment Method</h5>

                    <div class="mb-3">
                        <select class="form-select rounded-3" required>
                            <option selected disabled>Select Payment Method</option>
                            <option>Credit Card</option>
                            <option>Debit Card</option>
                            <option>UPI</option>
                            <option>Net Banking</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <input type="text"
                                class="form-control rounded-3"
                                placeholder="Card Number">
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col">
                            <input type="text"
                                class="form-control rounded-3"
                                placeholder="Expiry Date (MM/YY)">
                        </div>
                        <div class="col">
                            <input type="text"
                                class="form-control rounded-3"
                                placeholder="CVV">
                        </div>
                    </div>

                    <button class="btn btn-success w-100 rounded-pill mt-3">
                        Confirm Booking
                    </button>

                </form>

            </div>

        </div>


        <!-- RIGHT SIDE - PRICE SUMMARY -->
        <div class="col-md-5">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <div class="d-flex align-items-center mb-3">
                    <img src="<%= listing.image.url %>"
                        class="rounded-3"
                        style="width:100px;height:80px;object-fit:cover;">
                    <div class="ms-3">
                        <h6 class="fw-bold mb-1"><%= listing.title %></h6>
                        <small class="text-muted">
                            <%= listing.location %>, <%= listing.country %>
                        </small>
                    </div>
                </div>

                <hr>

                <div class="d-flex justify-content-between mb-2">
                    <span>₹ <%= listing.price %> x <span id="days">0</span> nights</span>
                    <span id="price">₹ 0</span>
                </div>

                <div class="d-flex justify-content-between mb-2">
                    <span>Service Fee</span>
                    <span>₹ 500</span>
                </div>

                <hr>

                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Total</span>
                    <span id="total">₹ 0</span>
                </div>

            </div>

        </div>

    </div>

</div>


<script>
    const pricePerNight = <%= listing.price %>;

    const checkinInput = document.getElementById("checkin");
    const checkoutInput = document.getElementById("checkout");

    function calculate() {
        const checkin = new Date(checkinInput.value);
        const checkout = new Date(checkoutInput.value);

        if (checkin && checkout && checkout > checkin) {

            const timeDiff = checkout - checkin;
            const days = Math.ceil(timeDiff / (1000 * 60 * 60 * 24));

            const stayPrice = days * pricePerNight;
            const serviceFee = 500;
            const total = stayPrice + serviceFee;

            document.getElementById("days").innerText = days;
            document.getElementById("price").innerText = "₹ " + stayPrice;
            document.getElementById("total").innerText = "₹ " + total;
        }
    }

    checkinInput.addEventListener("change", calculate);
    checkoutInput.addEventListener("change", calculate);
</script>